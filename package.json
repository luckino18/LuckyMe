{
  "name": "luckyme",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/luckino18/LuckyMe.git"
  },
  "type": "module",
  "scripts": {
    "app:typecheck": "npm --prefix app-seeker run typecheck",
    "app:validate:production": "npm --prefix app-seeker run validate:production",
    "app:build:dapp-store": "npm --prefix app-seeker run build:dapp-store",
    "app:apk:verify": "npm --prefix app-seeker run apk:verify",
    "audit:mainnet-release": "node scripts/audit-mainnet-release.mjs",
    "backend:start": "node backend/src/server.mjs",
    "backend:validate:production": "LUCKYME_VALIDATE_CONFIG_ONLY=true node backend/src/server.mjs",
    "wallet:plan": "node scripts/mainnet-wallet-plan.mjs",
    "keeper:configure": "node scripts/configure-keeper-ledger.mjs",
    "keeper:configure:ledger": "node scripts/configure-keeper-ledger.mjs",
    "keeper:configure:localnet": "node scripts/configure-keeper.mjs",
    "init:pools": "node scripts/init-pools.mjs",
    "init:pools:ledger": "node scripts/init-pools-ledger.mjs",
    "localnet:smoke": "node scripts/localnet-smoke.mjs",
    "round:open": "node scripts/open-round.mjs",
    "round:settle": "node scripts/settle-round.mjs",
    "round:close-empty": "node scripts/close-empty-round.mjs",
    "round:crank-empty": "node scripts/recover-legacy-empty-round-rent.mjs",
    "rent:recover:legacy-empty": "node scripts/recover-legacy-empty-round-rent.mjs",
    "incident:forensics": "node scripts/incident-forensics.mjs",
    "push:round-alerts": "node scripts/push-round-alerts.mjs",
    "monitor:operations": "node scripts/operations-monitor.mjs",
    "refund:crank": "node scripts/refund-cranker.mjs",
    "randomness:request": "node scripts/randomness-request.mjs",
    "randomness:status": "node scripts/randomness-status.mjs",
    "randomness:settle": "node scripts/randomness-settle.mjs",
    "settlement:keeper": "node scripts/settlement-keeper.mjs",
    "test:anchor": "NO_DNA=1 anchor test --provider.cluster localnet --validator legacy -- --features test-short-timers",
    "build:web:walletconnect": "node scripts/build-walletconnect-browser.mjs",
    "capture:web-fix-screenshots": "node scripts/capture-web-fix-screenshots.mjs",
    "test": "node --test sim/*.test.mjs tests/backend-config.test.mjs tests/backend-minimums-ui.test.mjs tests/app-production-env.test.mjs tests/deploy-safety.test.mjs tests/docs-scripts.test.mjs tests/legacy-empty-rent-recovery.test.mjs tests/lifecycle-rent-wallet.test.mjs tests/wallet-standard.test.mjs tests/walletconnect-flow.test.mjs tests/pool-card-layout.test.mjs tests/push-notifications.test.mjs",
    "sim:preview": "node sim/preview.mjs"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "0.32.1",
    "@ledgerhq/hw-app-solana": "^7.10.5",
    "@ledgerhq/hw-transport-node-hid": "^6.33.5",
    "@solana/web3.js": "1.98.4",
    "@walletconnect/universal-provider": "2.23.9",
    "esbuild": "0.25.6",
    "playwright-core": "1.55.0",
    "qrcode": "1.5.4"
  },
  "dependencies": {
    "@orao-network/solana-vrf": "0.8.0"
  }
}
