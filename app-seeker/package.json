{
  "name": "luckyme-seeker",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "android": "expo run:android",
    "apk:verify": "apksigner verify --print-certs ${APK_PATH:-app-release.apk}",
    "build:dapp-store": "eas build --platform android --profile dapp-store",
    "doctor": "expo-doctor",
    "prebuild:android": "expo prebuild --platform android",
    "start": "expo start --dev-client",
    "start:go": "expo start",
    "validate:production": "node scripts/validate-production-env.mjs",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web"
  },
  "dependencies": {
    "@craftzdog/react-native-buffer": "^6.1.2",
    "@solana/web3.js": "^1.98.4",
    "@wallet-ui/react-native-web3js": "^4.2.0",
    "expo": "57.0.2",
    "expo-build-properties": "^57.0.3",
    "expo-dev-client": "^57.0.5",
    "expo-splash-screen": "~57.0.2",
    "expo-system-ui": "^57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-quick-base64": "^3.0.0",
    "react-native-quick-crypto": "^1.1.5"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "expo-doctor": "^1.20.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "@wallet-standard/react-core": {
      "react": "19.2.3",
      "react-dom": "19.2.3"
    }
  }
}
