{
  "name": "luckyme-seeker",
  "version": "1.2.6",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "android": "expo run:android",
    "apk:verify": "apksigner verify --print-certs ${APK_PATH:-app-release.apk}",
    "build:seeker-referral-test": "node scripts/build-seeker-referral-test.mjs",
    "build:seeker-pass-test": "node scripts/build-seeker-pass-test.mjs",
    "build:ui-test": "node scripts/build-ui-test.mjs",
    "generate:webview-assets": "node scripts/generate-webview-theme-assets.mjs",
    "keystore:seeker-referral-test": "node scripts/ensure-test-keystore.mjs",
    "build:dapp-store": "npx --yes eas-cli@20.5.1 build --platform android --profile dapp-store",
    "doctor": "expo-doctor",
    "prebuild:android": "expo prebuild --platform android",
    "start": "expo start --dev-client",
    "start:go": "expo start",
    "validate:production": "node scripts/validate-production-env.mjs",
    "typecheck": "node scripts/generate-webview-theme-assets.mjs && tsc --noEmit",
    "web": "expo start --web"
  },
  "dependencies": {
    "@craftzdog/react-native-buffer": "^6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@solana/web3.js": "^1.98.4",
    "@wallet-ui/react-native-web3js": "^4.2.0",
    "expo": "~57.0.8",
    "expo-application": "~57.0.2",
    "expo-build-properties": "~57.0.7",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.7",
    "expo-dev-client": "~57.0.9",
    "expo-notifications": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.5",
    "expo-system-ui": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-quick-base64": "^3.0.0",
    "react-native-quick-crypto": "^1.1.5",
    "react-native-svg": "15.15.4",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "expo-doctor": "^1.20.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "@wallet-standard/react-core": {
      "react": "19.2.3",
      "react-dom": "19.2.3"
    }
  }
}
