{
  "expo": {
    "name": "LuckyMe",
    "slug": "luckyme-seeker",
    "version": "1.1.2",
    "orientation": "portrait",
    "scheme": "luckyme",
    "userInterfaceStyle": "dark",
    "androidStatusBar": {
      "hidden": true,
      "translucent": true,
      "backgroundColor": "#00000000",
      "barStyle": "light-content"
    },
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.luckyme.seeker",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E14"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "extra": {
      "luckymeProgramId": "4bndxrGfuUcSLJnbCu8vs9WZ4qHdKGwcoeCybNThkrA3",
      "solanaCluster": "mainnet-beta",
      "eas": {
        "projectId": "e054857c-6dfb-46ec-9d60-09ce2150dcc4"
      }
    },
    "plugins": [
      "./plugins/with-luckyme-immersive-android",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0A0E14"
        }
      ]
    ]
  }
}
