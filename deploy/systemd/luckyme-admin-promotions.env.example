LUCKYME_ADMIN_PROMOTIONS_HOST=127.0.0.1
LUCKYME_ADMIN_PROMOTIONS_PORT=8793
LUCKYME_ADMIN_PROMOTIONS_RPC_URL=https://api.mainnet-beta.solana.com
LUCKYME_PROMOTIONS_DB_PATH=/var/lib/luckyme-promotions/promotional-pools.sqlite
LUCKYME_PROMOTIONS_SPONSOR=REPLACE_WITH_FUNDING_WALLET
LUCKYME_PROMOTIONS_AUTHORIZER_KEYPAIR=/etc/luckyme/promotion-authorizer.json
LUCKYME_PROMOTIONS_ENABLED=false
CONFIRM_MAINNET_PROMOTIONS_KEEPER=false
LUCKYME_PROMOTIONS_KEEPER_MAX_ACTIONS=4
LUCKYME_PUSH_TOKEN_STORE=/var/lib/luckyme/push-tokens.json
LUCKYME_PUSH_SEND=false

# Safe release order: enable preparation first, verify the UI and treasury,
# then enable execution only after the matching program upgrade is confirmed.
LUCKYME_ADMIN_PROMOTIONS_PREPARE_ENABLED=false
LUCKYME_ADMIN_PROMOTIONS_EXECUTION_ENABLED=false

# Configure these in /etc/luckyme/luckyme-api.env for automatic Discord tasks.
# LUCKYME_DISCORD_CLIENT_ID=
# LUCKYME_DISCORD_CLIENT_SECRET=
# LUCKYME_DISCORD_GUILD_ID=
# LUCKYME_DISCORD_REDIRECT_URI=https://api.lucky-me.app/api/promotions/oauth/discord/callback
