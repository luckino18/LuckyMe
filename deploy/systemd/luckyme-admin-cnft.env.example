# Install as /etc/luckyme/admin-cnft.env with owner root:luckyme and mode 0640.
# Use a dedicated RPC key with the smallest available quota and no wallet permissions.
LUCKYME_ADMIN_CNFT_RPC_URL=https://api.mainnet-beta.solana.com
LUCKYME_ADMIN_CNFT_DAS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=REPLACE_WITH_DEDICATED_KEY
LUCKYME_ADMIN_SKR_REGISTRY_PATH=/var/lib/luckyme/admin-skr-registry.json
LUCKYME_ADMIN_CNFT_JOB_STORE_PATH=/var/lib/luckyme/admin-cnft-jobs.json

# Keep false until the protected Admin UI, DAS duplicate check, authority wallet,
# simulation and a one-recipient test have all been verified on the VPS.
LUCKYME_ADMIN_CNFT_EXECUTION_ENABLED=false
